# Plantilla de variables de entorno.
# Copia este archivo a .env y completa los valores reales.
# IMPORTANTE: .env NO se sube a git (contiene secretos). Esto si se versiona.

# URL publica del sitio (SEO / metadata)
NEXT_PUBLIC_SITE_URL=https://dioptrika.com

# Payphone (Panel de desarrolladores > Configuracion)
# El "Token" se usa en el navegador (cajita) y en el backend (confirmacion): mismo valor.
NEXT_PUBLIC_PAYPHONE_TOKEN=tu_token_payphone
NEXT_PUBLIC_PAYPHONE_STORE_ID=tu_store_id
PAYPHONE_TOKEN=tu_token_payphone

# Firma HMAC para clientTransactionId (valor aleatorio largo, 64+ caracteres)
PAYPHONE_HMAC_SECRET=genera_un_valor_aleatorio_largo

# Email (Resend): deja RESEND_API_KEY vacio para deshabilitar el envio de correos
RESEND_API_KEY=
RESEND_FROM="Dioptrika <no-reply@dioptrika.com>"
NOTIFY_EMAIL=correo_donde_recibes_notificaciones
